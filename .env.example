DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
JWT_SECRET=PASTE_A_LONG_RANDOM_SECRET_HERE

# Both values are server-only — do NOT prefix with VITE_, or they will be
# bundled into the browser JS. Set these in Vercel's dashboard for
# production (Project Settings -> Environment Variables) and in a local,
# gitignored .env file for `vercel dev`.
