DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
JWT_SECRET=PASTE_A_LONG_RANDOM_SECRET_HERE

# Optional — SMS notifications no-op (log + skip) until configured.
# TWILIO_ACCOUNT_SID + TWILIO_PHONE_NUMBER are always required. For auth, use
# EITHER an API Key (preferred: TWILIO_API_KEY_SID + TWILIO_API_KEY_SECRET)
# OR the main Auth Token (TWILIO_AUTH_TOKEN) — not both are needed.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# All values above are server-only — do NOT prefix with VITE_, or they will
# be bundled into the browser JS. Set these in Vercel's dashboard for
# production (Project Settings -> Environment Variables) and in a local,
# gitignored .env file for `vercel dev`.
